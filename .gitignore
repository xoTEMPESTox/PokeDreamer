# Pokémon Red RL — .gitignore

# ROM (never commit)
*.gb
*.gbc
*.ram

# Logs and trajectories
logs/
*.jsonl

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Conda / virtualenv
.env
.venv
env/

# PyBoy / emulator saves created at runtime
*.state.bak

# Checkpoints — exclude large model files; keep videos and images
checkpoints/
!checkpoints/**/*.mp4
!checkpoints/**/*.png

# v2 archive — exclude model weights, keep code + videos + images
v2/checkpoints/**/*.pt
!v2/checkpoints/**/*.mp4
!v2/checkpoints/**/*.png

# Jupyter
.ipynb_checkpoints/

# OS
.DS_Store
Thumbs.db

# Custom additions
external/
saves/
scratch/
data/
